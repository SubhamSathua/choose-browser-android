<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ChooseBrowserNEW" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>
    <!--======== Default Colors ========-->
    <style name="Theme.ChooseBrowserNEW" parent="Base.Theme.ChooseBrowserNEW">
        <item name="android:statusBarColor">@color/backgroundPrimary</item>
        <item name="android:navigationBarColor">@color/backgroundPrimary</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="colorControlActivated">@color/text</item>
        <item name="android:colorControlActivated">@color/text</item>
        <item name="colorAccent">@color/text</item>
        <item name="android:colorAccent">@color/text</item>

    </style>

    <!-- Core color-theme overlays (light). Values-night auto-overrides referenced colors. -->
    <style name="ThemeOverlay.ChooseBrowserNEW.Color.default" parent="">
        <item name="colorPopupSurface">@color/PopUpCardBg</item>
        <item name="colorPopupDock">@color/PopUpCardDockBg</item>
        <item name="colorPopupDockButton">@color/PopUpCardDockBtn</item>
        <item name="colorPopupDockButtonText">@color/PopUpCardDockText</item>
        <item name="colorPopupAction">@color/PopUpCard_ActionBtnBg</item>
        <item name="colorPopupText">@color/text</item>
    </style>

    <style name="ThemeOverlay.ChooseBrowserNEW.Color.eclipse" parent="">
        <item name="colorPopupSurface">@color/copilot_popup_surface</item>
        <item name="colorPopupDock">@color/copilot_popup_dock</item>
        <item name="colorPopupDockButton">@color/copilot_popup_dock_button</item>
        <item name="colorPopupDockButtonText">@color/copilot_popup_dock_button_text</item>
        <item name="colorPopupAction">@color/copilot_popup_action</item>
        <item name="colorPopupText">@color/copilot_popup_text</item>
    </style>

    <style name="ThemeOverlay.ChooseBrowserNEW.Color.neuronight" parent="">
        <item name="colorPopupSurface">@color/dracula_popup_surface</item>
        <item name="colorPopupDock">@color/dracula_popup_dock</item>
        <item name="colorPopupDockButton">@color/dracula_popup_dock_button</item>
        <item name="colorPopupDockButtonText">@color/dracula_popup_dock_button_text</item>
        <item name="colorPopupAction">@color/dracula_popup_action</item>
        <item name="colorPopupText">@color/dracula_popup_text</item>
    </style>

    <style name="ThemeOverlay.ChooseBrowserNEW.Color.neural_blue" parent="">
        <item name="colorPopupSurface">@color/PopUpCardBg</item>
        <item name="colorPopupDock">@color/PopUpCardDockBg</item>
        <item name="colorPopupDockButton">@color/PopUpCardDockBtn</item>
        <item name="colorPopupDockButtonText">@color/PopUpCardDockText</item>
        <item name="colorPopupAction">@color/PopUpCard_ActionBtnBg</item>
        <item name="colorPopupText">@color/text</item>
    </style>

    <style name="ThemeOverlay.ChooseBrowserNEW.Color.cosmic" parent="">
        <item name="colorPopupSurface">@color/PopUpCardBg</item>
        <item name="colorPopupDock">@color/PopUpCardDockBg</item>
        <item name="colorPopupDockButton">@color/PopUpCardDockBtn</item>
        <item name="colorPopupDockButtonText">@color/PopUpCardDockText</item>
        <item name="colorPopupAction">@color/PopUpCard_ActionBtnBg</item>
        <item name="colorPopupText">@color/text</item>
    </style>

    <style name="ThemeOverlay.ChooseBrowserNEW.Color.obsidian_pulse" parent="">
        <item name="colorPopupSurface">@color/PopUpCardBg</item>
        <item name="colorPopupDock">@color/PopUpCardDockBg</item>
        <item name="colorPopupDockButton">@color/PopUpCardDockBtn</item>
        <item name="colorPopupDockButtonText">@color/PopUpCardDockText</item>
        <item name="colorPopupAction">@color/PopUpCard_ActionBtnBg</item>
        <item name="colorPopupText">@color/text</item>
    </style>

    <!-- Preview More bottom sheet: transparent bg so our drawable shows -->
    <style name="PreviewMoreBottomSheet" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/PreviewMoreBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:navigationBarColor">@color/previewPage_primary</item>
    </style>

    <style name="PreviewMoreBottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="shapeAppearanceOverlay">@style/PreviewMoreShapeOverlay</item>
    </style>

    <style name="PreviewMoreShapeOverlay">
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
    </style>



</resources>



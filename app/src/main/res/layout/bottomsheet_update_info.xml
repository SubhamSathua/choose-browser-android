<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_preview_more_sheet"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_preview_drag_handle" />

    <!-- Title = short_msg -->
    <TextView
        android:id="@+id/updateInfoTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_medium"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp"
        android:text="Update Available"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold" />

    <!-- md_file URL (not rendered yet) -->
    <TextView
        android:id="@+id/updateInfoMdFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_light"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp"
        android:textColor="#B0B3B8"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <Button
            android:id="@+id/updateInfoCloseBtn"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:text="Close"
            android:textColor="#B0B3B8"
            android:visibility="gone" />

        <Button
            android:id="@+id/updateInfoBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#377aff"
            android:fontFamily="@font/poppins_regular"
            android:text="Update"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>

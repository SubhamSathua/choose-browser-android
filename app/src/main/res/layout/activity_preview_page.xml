<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/previewPage_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Address Bar -->
        <LinearLayout
            android:id="@+id/addressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/previewPage_primary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp">

            <!-- Reload Button -->
            <ImageButton
                android:id="@+id/btnReload"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_preview_addr_btn_ripple"
                android:contentDescription="Reload"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/reload" />

            <!-- URL bar (incognito icon + editable text + clear) -->
            <LinearLayout
                android:id="@+id/urlBox"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_preview_url_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <ImageView
                    android:id="@+id/urlSiteIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/site_icon_demo" />

                <ImageView
                    android:id="@+id/urlIncognitoIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ix_incognito" />

                <EditText
                    android:id="@+id/etUrl"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:cursorVisible="true"
                    android:ellipsize="end"
                    android:fontFamily="@font/poppins"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="@color/previewPage_textSecondary"
                    android:textColorHint="#88ffffff"
                    android:hint="Search or type URL"
                    android:textSize="12sp" />

                <!-- Clear text (X) button, shown only when focused -->
                <ImageButton
                    android:id="@+id/btnClearUrl"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Clear"
                    android:padding="5dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/close"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- JS Toggle Button -->
            <ImageButton
                android:id="@+id/btnToggleJs"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_preview_addr_btn_ripple"
                android:contentDescription="Toggle JavaScript"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/js_off" />

            <!-- Close Button -->
            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_preview_addr_btn_ripple"
                android:contentDescription="Close"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/close" />
        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_bar_preview"
            android:visibility="gone" />

        <!-- Focus actions bar (Copy, Share) – shown when URL bar is focused -->
        <LinearLayout
            android:id="@+id/focusActionsBar"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@color/previewPage_primary"
            android:gravity="center_vertical|end"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/focusBtnCopy"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_preview_addr_action_btn"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/ix_copy" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="Copy"
                    android:textColor="@color/previewPage_textSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/focusBtnShare"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_preview_addr_action_btn"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/ix_share" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="Share"
                    android:textColor="@color/previewPage_textSecondary"
                    android:textSize="12sp" />

            </LinearLayout>
        </LinearLayout>

        <!-- Custom Find Bar (shown on demand) -->
        <LinearLayout
            android:id="@+id/findBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/previewPage_secondary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etFind"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_preview_url_box"
                android:fontFamily="@font/poppins"
                android:hint="Find in page…"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textColor="@color/previewPage_textSecondary"
                android:textColorHint="#88ffffff"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvFindCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:fontFamily="@font/poppins"
                android:text="0/0"
                android:textColor="#99ffffff"
                android:textSize="12sp" />

            <ImageButton
                android:id="@+id/btnFindPrev"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_preview_addr_btn_ripple"
                android:contentDescription="Previous result"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/back" />

            <ImageButton
                android:id="@+id/btnFindNext"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_preview_addr_btn_ripple"
                android:contentDescription="Next result"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/forward" />

            <ImageButton
                android:id="@+id/btnFindClose"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_preview_copy_btn_hover"
                android:contentDescription="Close find"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/close" />
        </LinearLayout>

        <!-- WebView -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom Navigation Bar -->
        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/previewPage_primary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <!-- Back -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/back"
                android:alpha="0.4" />

            <!-- Forward -->
            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Forward"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/forward"
                android:alpha="0.4" />

            <!-- Search / URL -->
            <ImageButton
                android:id="@+id/btnSearch"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Search"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ix_search" />

            <!-- Fire (Clear & Exit) -->
            <ImageButton
                android:id="@+id/btnFire"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear and Exit"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/fire" />

            <!-- More menu -->
            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="More"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/menu" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>

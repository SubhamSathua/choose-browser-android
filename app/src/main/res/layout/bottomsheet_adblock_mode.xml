<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_preview_more_sheet"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_preview_drag_handle" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/poppins"
        android:text="Ad-Blocker Mode"
        android:textColor="@color/previewPage_textSecondary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="14dp"
        android:fontFamily="@font/poppins"
        android:text="Choose blocking strategy for ads and trackers."
        android:textColor="#99ffffff"
        android:textSize="12sp" />

    <!-- ─── Domain Filter List ─── -->
    <LinearLayout
        android:id="@+id/adBlockModeFilter"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_preview_grid_item_hover"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ad_close" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Domain Filter List"
                android:textColor="@color/previewPage_textSecondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Block known ad &amp; tracker domains"
                android:textColor="#99ffffff"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/adBlockCheckFilter"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ix_permitted"
            android:visibility="visible" />
    </LinearLayout>

    <!-- ─── AdGuard DNS ─── -->
    <LinearLayout
        android:id="@+id/adBlockModeDns"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_preview_grid_item_hover"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/shield_lock_24px" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="AdGuard DNS"
                android:textColor="@color/previewPage_textSecondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Extended blocking with DNS-level filtering"
                android:textColor="#99ffffff"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/adBlockCheckDns"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ix_permitted"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>

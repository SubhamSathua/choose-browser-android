<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_permission_dialog"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:layout_marginHorizontal="15dp"
    android:layout_marginVertical="15dp"
    android:paddingTop="28dp"
    android:paddingBottom="20dp">

    <!-- Icon + message row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/permIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/shield_lock_24px"
            android:tint="#ffffff" />

        <TextView
            android:id="@+id/permMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/poppins"
            android:text="site.com wants to use your camera/file/audio/..."
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <!-- Allow ONLY this time -->
    <TextView
        android:id="@+id/btnAllowOnce"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_permission_btn_allow"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/poppins_medium"
        android:gravity="center"
        android:text="Allow ONLY this time"
        android:textColor="#ffffff"
        android:textSize="15sp" />

    <!-- Don't Allow -->
    <TextView
        android:id="@+id/btnDontAllow"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_permission_btn_deny"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/poppins_medium"
        android:gravity="center"
        android:text="Don&apos;t Allow"
        android:textColor="#000000"
        android:textSize="15sp" />

</LinearLayout>

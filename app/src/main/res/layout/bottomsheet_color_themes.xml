<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/colorThemesSheetRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/backgroundSecondary"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingTop="8dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="6dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:src="@drawable/ix_drag_handle" />
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="4dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ix_palette" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:text="@string/color_themes"
                android:textColor="@color/text"
                android:textSize="20sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/colorThemesCloseBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_show_link_close_btn"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_close_24" />
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_regular"
        android:paddingHorizontal="8dp"
        android:paddingBottom="10dp"
        android:text="@string/color_themes_sub"
        android:textColor="@color/textSubSecondary"
        android:textSize="12sp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/backgroundPrimary"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp">

        <RadioGroup
            android:id="@+id/colorThemesRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <RadioButton
                android:id="@+id/colorThemeRadioDefault"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/PriBtn_BgCol"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/color_theme_default"
                android:textColor="@color/text" />

            <RadioButton
                android:id="@+id/colorThemeRadioDracula"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/PriBtn_BgCol"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/color_theme_dracula"
                android:textColor="@color/text" />

            <RadioButton
                android:id="@+id/colorThemeRadioCopilot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/PriBtn_BgCol"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/color_theme_copilot"
                android:textColor="@color/text" />

            <RadioButton
                android:id="@+id/colorThemeRadioTheme4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/PriBtn_BgCol"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/color_theme_theme4"
                android:textColor="@color/text" />
        </RadioGroup>
    </androidx.cardview.widget.CardView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_show_link_dialog"
    android:orientation="vertical"
    android:layout_marginHorizontal="15dp"
    android:layout_marginVertical="15dp"
    android:padding="20dp">

    <!-- Header: icon + title + close button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/link" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:text="Full Link"
                android:textColor="@color/showLinkDialog_textSecondary"
                android:textSize="20sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/showLinkCloseBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_show_link_close_btn"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_close_24" />

    </RelativeLayout>

    <!-- Scrollable link area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:maxHeight="280dp"
        android:background="@drawable/bg_show_link_url_box"
        android:fadeScrollbars="false"
        android:scrollbarSize="5dp"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb_show_link"
        android:scrollbarTrackVertical="@drawable/scrollbar_track_show_link"
        android:scrollbars="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/showLinkUrlText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:breakStrategy="simple"
            android:fontFamily="@font/poppins"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/showLinkDialog_textSecondary"
            android:textIsSelectable="true"
            android:textSize="13sp" />
    </ScrollView>

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="end"
        android:orientation="horizontal">

        <!-- Share button -->
        <LinearLayout
            android:id="@+id/showLinkShareBtn"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_show_link_share_btn"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/share_ico" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:text="Share"
                android:textColor="@color/showLinkDialog_textSecondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Copy Clean Link button -->
        <LinearLayout
            android:id="@+id/showLinkCopyCleanBtn"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_show_link_copy_clean_btn"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/copy_invert"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:text="Copy Clean Link"
                android:textColor="@color/showLinkDialog_textPrimary"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

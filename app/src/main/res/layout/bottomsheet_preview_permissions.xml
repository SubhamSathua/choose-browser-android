<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_preview_more_sheet"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_preview_drag_handle" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/poppins"
        android:text="App Permissions"
        android:textColor="@color/previewPage_textSecondary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="14dp"
        android:fontFamily="@font/poppins"
        android:text="Tap to allow, or tap a granted permission to manage it in system settings."
        android:textColor="#99ffffff"
        android:textSize="12sp" />

    <!-- ─── Camera ─── -->
    <LinearLayout
        android:id="@+id/permRowCamera"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_preview_grid_item_hover"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ix_permissions" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Camera"
                android:textColor="@color/previewPage_textSecondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/permStatusCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Not granted"
                android:textColor="#FF5252"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/permActionCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_preview_addr_action_btn"
            android:fontFamily="@font/poppins"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Allow"
            android:textColor="@color/previewPage_textSecondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- ─── Microphone ─── -->
    <LinearLayout
        android:id="@+id/permRowMic"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_preview_grid_item_hover"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ix_permissions" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Microphone"
                android:textColor="@color/previewPage_textSecondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/permStatusMic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Not granted"
                android:textColor="#FF5252"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/permActionMic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_preview_addr_action_btn"
            android:fontFamily="@font/poppins"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Allow"
            android:textColor="@color/previewPage_textSecondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- ─── Location ─── -->
    <LinearLayout
        android:id="@+id/permRowLocation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_preview_grid_item_hover"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ix_permissions" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Location"
                android:textColor="@color/previewPage_textSecondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/permStatusLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Not granted"
                android:textColor="#FF5252"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/permActionLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_preview_addr_action_btn"
            android:fontFamily="@font/poppins"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Allow"
            android:textColor="@color/previewPage_textSecondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- ─── Storage ─── -->
    <LinearLayout
        android:id="@+id/permRowStorage"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_preview_grid_item_hover"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ix_permissions" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Storage"
                android:textColor="@color/previewPage_textSecondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/permStatusStorage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Not granted"
                android:textColor="#FF5252"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/permActionStorage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_preview_addr_action_btn"
            android:fontFamily="@font/poppins"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Allow"
            android:textColor="@color/previewPage_textSecondary"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
